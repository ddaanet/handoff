{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PROJECT_DIR}/plugin-dev/version-guard.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "revdiff@revdiff": true,
    "superpowers@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "gitlore@ddaanet": true,
    "plugin-dev@claude-plugins-official": true,
    "shell-scripting@ddaanet": true
  },
  "gitlore": {
    "enabled": true,
    "precommitCommand": "just precommit"
  }
}
